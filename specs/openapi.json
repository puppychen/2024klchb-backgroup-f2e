  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Enter JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "CreateAdminDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateAdminDto": {
        "type": "object",
        "properties": {}
      },
      "CreateFacilityDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateFacilityDto": {
        "type": "object",
        "properties": {}
      },
      "ChildResponseDto": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "子女資料 UUID"
          },
          "name": {
            "type": "string",
            "description": "子女姓名"
          },
          "birthDate": {
            "format": "date-time",
            "type": "string",
            "description": "出生日期"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "建立時間"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新時間"
          }
        },
        "required": [
          "uuid",
          "name",
          "birthDate",
          "createdAt",
          "updatedAt"
        ]
      },
      "NoteResponseDto": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "筆記 UUID"
          },
          "title": {
            "type": "string",
            "description": "筆記標題"
          },
          "content": {
            "type": "string",
            "description": "筆記內容"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "建立時間"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新時間"
          },
          "NoteEditHistory": {
            "description": "筆記編輯歷史",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteEditHistoryResponseDto"
            }
          }
        },
        "required": [
          "uuid",
          "title",
          "content",
          "createdAt",
          "updatedAt"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "用戶 UUID"
          },
          "lineId": {
            "type": "string",
            "description": "LINE ID"
          },
          "name": {
            "type": "string",
            "description": "用戶姓名",
            "nullable": true
          },
          "content": {
            "type": "object",
            "description": "用戶附加資料",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "建立時間"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新時間"
          },
          "Children": {
            "description": "子女資料列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChildResponseDto"
            }
          },
          "Note": {
            "description": "筆記列表",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteResponseDto"
            }
          }
        },
        "required": [
          "uuid",
          "lineId",
          "name",
          "content",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateChildDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateChildDto": {
        "type": "object",
        "properties": {}
      },
      "NoteEditHistoryResponseDto": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "編輯歷史 UUID"
          },
          "beforeContent": {
            "type": "string",
            "description": "編輯前內容",
            "nullable": true
          },
          "afterContent": {
            "type": "string",
            "description": "編輯後內容",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "建立時間"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "更新時間"
          }
        },
        "required": [
          "uuid",
          "beforeContent",
          "afterContent",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateNoteDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateNoteDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
